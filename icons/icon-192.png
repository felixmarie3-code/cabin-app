<svg xmlns="http://www.w3.org/2000/svg" width="192" height="192" viewBox="0 0 192 192">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#0d0f2b"/>
      <stop offset="100%" stop-color="#1a1d4a"/>
    </linearGradient>
  </defs>
  <rect width="192" height="192" rx="42" fill="url(#bg)"/>
  <!-- Airplane icon — clean, geometric, front-facing -->
  <g transform="translate(96, 86)">
    <!-- Fuselage -->
    <path d="M0,-52 C4,-52 6,-48 6,-40 L6,28 C6,32 4,36 0,40 C-4,36 -6,32 -6,28 L-6,-40 C-6,-48 -4,-52 0,-52Z" fill="white" opacity="0.92"/>
    <!-- Wings -->
    <path d="M6,-6 L52,14 C54,15 54,18 52,19 L6,8Z" fill="#52A7BE" opacity="0.8"/>
    <path d="M-6,-6 L-52,14 C-54,15 -54,18 -52,19 L-6,8Z" fill="#52A7BE" opacity="0.8"/>
    <!-- Tail fin -->
    <path d="M0,-52 L0,-62 C0,-64 2,-65 4,-63 L6,-52 L0,-48Z" fill="#355EAB" opacity="0.9"/>
    <path d="M0,-52 L0,-62 C0,-64 -2,-65 -4,-63 L-6,-52 L0,-48Z" fill="#355EAB" opacity="0.7"/>
    <!-- Tail wings -->
    <path d="M6,-44 L22,-50 C23,-50 24,-49 23,-48 L6,-40Z" fill="#52A7BE" opacity="0.5"/>
    <path d="M-6,-44 L-22,-50 C-23,-50 -24,-49 -23,-48 L-6,-40Z" fill="#52A7BE" opacity="0.5"/>
    <!-- Engines -->
    <ellipse cx="20" cy="12" rx="4" ry="6" fill="white" opacity="0.25"/>
    <ellipse cx="-20" cy="12" rx="4" ry="6" fill="white" opacity="0.25"/>
    <!-- Windshield -->
    <path d="M-3,-42 Q0,-46 3,-42 L3,-36 Q0,-34 -3,-36Z" fill="#52A7BE" opacity="0.5"/>
  </g>
  <!-- Neoline -->
  <line x1="46" y1="162" x2="146" y2="162" stroke="#DA3D32" stroke-width="2.5" stroke-linecap="round"/>
</svg>
